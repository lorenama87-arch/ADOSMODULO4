# --- SISTEMA DE SEGURIDAD DE LA APP ---
def check_password():
    """Devuelve True si el usuario ingresó la contraseña correcta."""
    def password_entered():
        # Comprueba si la contraseña ingresada coincide con el "Secreto" del servidor
        if st.session_state["password"] == st.secrets["password"]:
            st.session_state["password_correct"] = True
            del st.session_state["password"]  # Borramos la clave de la memoria por seguridad
        else:
            st.session_state["password_correct"] = False

    # Si es la primera vez que entra a la web, muestra el input
    if "password_correct" not in st.session_state:
        st.text_input("🔐 Introduce la contraseña de acceso:", type="password", on_change=password_entered, key="password")
        return False
    # Si la metió mal
    elif not st.session_state["password_correct"]:
        st.text_input("🔐 Introduce la contraseña de acceso:", type="password", on_change=password_entered, key="password")
        st.error("Contraseña incorrecta. Acceso denegado.")
        return False
    # Si la contraseña es correcta, permite pasar
    else:
        return True

# Si la verificación falla, detenemos la ejecución de todo el script aquí mismo.
if not check_password():
    st.stop()

# 1. LÓGICA DE PUNTUACIÓN
def c(v):
    """Conversión oficial del algoritmo (3->2, 7/8/9->0)"""
    if v in [0, 7, 8, 9]: return 0
    if v == 1: return 1
    if v in [2, 3]: return 2
    return 0

