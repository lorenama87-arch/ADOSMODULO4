# 3. INTERFAZ Y RECOLECCIÓN DE DATOS
st.set_page_config(page_title="ADOS-2 Master M4", layout="wide")
st.title("🔬 Sistema de Evaluación ADOS-2 Módulo 4")

with st.sidebar:
    gen = st.radio("Género:", ["Varón", "Mujer"])
    edad = st.number_input("Edad:", 12, 99, 25)
    art = "El evaluado" if gen == "Varón" else "La evaluada"
    del_al = "del evaluado" if gen == "Varón" else "de la evaluada"

tabs_names = ["Tareas"] + list(UI_STRUCTURE.keys())
tabs = st.tabs(tabs_names)

notas_tareas = {}
with tabs[0]:
    for t in TASKS:
        notas_tareas[t] = st.text_input(f"Notas breves: {t}", key=f"task_{t}")

scores = {}
for i, (section, items) in enumerate(UI_STRUCTURE.items()):
    with tabs[i+1]:
        for key, options in items:
            label = f"{key}*" if key in ALGO_KEYS else key
            scores[key] = st.radio(label, options, horizontal=True)

# 4. GENERACIÓN DEL INFORME
if st.button("🚀 GENERAR INFORME TOTAL"):
    
    sc_C = sum(c(scores[k]) for k in ["A4", "A8", "A9", "A10"])
    sc_ISR = sum(c(scores[k]) for k in ["B1", "B2", "B6", "B8", "B9", "B11", "B12"])
    total = sc_C + sc_ISR
    
    if sc_C >= 3 and sc_ISR >= 6 and total >= 10: clima = "AUTISMO"
    elif sc_C >= 2 and sc_ISR >= 4 and total >= 7: clima = "ESPECTRO AUTISTA"
    else: clima = "NO TEA"

    def get_text(k):
        """Obtiene el texto base reemplazando las variables dinámicas."""
        return TEXTOS.get(k, {}).get(scores[k], "").replace("{art}", art)

    def format_sentence(text):
        """Estandariza el texto: primera letra mayúscula y añade punto final si falta."""
        if not text: return ""
        text = text.strip()
        text = text[0].upper() + text[1:]
        if not text.endswith("."): text += "."
        return text + " "

    # Construcción narrativa de todas las secciones
    redA = f"{get_text('A1')} {get_text('A2')} En la interacción verbal, {get_text('A4').lower()} Asimismo, {get_text('A8').lower()} Respecto a la gestualidad, {get_text('A9').lower()} y {get_text('A10').lower()}"
    redB = f"{get_text('B1')} {get_text('B2')} Además, {get_text('B6').lower()} En cuanto a la conducta social, {get_text('B8').lower()}, {get_text('B9').lower()} y finalmente {get_text('B12').lower()}"
    
    # Ensamblaje secuencial limpio para C, D y E
    redC = format_sentence(get_text('C1'))
    
    redD = format_sentence(get_text('D1')) + format_sentence(get_text('D2')) + \
           format_sentence(get_text('D3')) + format_sentence(get_text('D4')) + \
           format_sentence(get_text('D5'))
           
    redE = format_sentence(get_text('E1')) + format_sentence(get_text('E2')) + \
           format_sentence(get_text('E3'))

